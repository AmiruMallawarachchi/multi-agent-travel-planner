# Public address. Use :80 for an IP-only deployment, or a domain such as
# tripweaver.example.com to let Caddy provision HTTPS automatically.
SITE_ADDRESS=:80
# Browser origin allowed by the backend if it is accessed directly.
PUBLIC_ORIGIN=http://replace-with-your-public-ip

# Provider credentials. Never commit the real values.
OPENAI_API_KEY=replace-me
SERPAPI_API_KEY=replace-me

# Use one long random value for both backend and frontend authentication.
TRIPWEAVER_API_KEY=replace-with-at-least-32-random-characters

# Model and application controls.
ROUTER_MODEL=gpt-4o-mini
AGENT_MODEL=gpt-4o-mini
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
MAX_MESSAGE_LENGTH=2000
