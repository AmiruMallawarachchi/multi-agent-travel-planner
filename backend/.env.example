# Copy to .env for local dev. In Railway, set these as service Variables -
# never commit a real .env (see .gitignore).

# --- LLM ---------------------------------------------------------------
OPENAI_API_KEY=sk-...
ROUTER_MODEL=gpt-4o-mini
AGENT_MODEL=gpt-4o-mini

# --- MCP servers ---------------------------------------------------------
# Local dev (docker compose): the defaults below already match compose's
# service names. In production, point these at your deployed MCP services.
HOTEL_MCP_URL=http://localhost:8001/mcp
FLIGHT_MCP_URL=http://localhost:8002/mcp

# --- Security (see SECURITY.md) ------------------------------------------
# Comma-separated list of accepted X-API-Key values. Leave empty ONLY for
# local dev - main.py logs a loud warning and runs unauthenticated if unset.
TRIPWEAVER_API_KEYS=change-me-to-a-long-random-string
# Comma-separated list of allowed CORS origins, e.g. your deployed Hugging
# Face Space URL and http://localhost:7860 for local frontend dev.
ALLOWED_ORIGINS=http://localhost:7860
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
MAX_MESSAGE_LENGTH=2000
