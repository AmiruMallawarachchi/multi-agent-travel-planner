# Copy to .env for local dev. In Render/Railway, set these as service variables -
# never commit a real .env (see .gitignore).

# --- LLM ---------------------------------------------------------------
OPENAI_API_KEY=sk-...
ROUTER_MODEL=gpt-4o-mini
AGENT_MODEL=gpt-4o-mini

# --- MCP servers ---------------------------------------------------------
# Local dev (docker compose): the defaults below already match compose's
# service names. In production, point these at your deployed MCP services.
HOTEL_MCP_URL=http://localhost:8001/mcp
FLIGHT_MCP_URL=http://localhost:8002/mcp
ITINERARY_MCP_URL=http://localhost:8003/mcp
WEATHER_MCP_URL=http://localhost:8004/mcp
CURRENCY_MCP_URL=http://localhost:8005/mcp
LOCATION_MCP_URL=http://localhost:8006/mcp
# Use "mcp" for the normal multi-service topology. Use "local" for the
# Vercel + Render + Supabase bootcamp demo so one backend process owns tools.
TRIPWEAVER_TOOL_MODE=mcp

# --- Security (see SECURITY.md) ------------------------------------------
# Comma-separated list of accepted X-API-Key values. Leave empty ONLY for
# local dev - main.py logs a loud warning and runs unauthenticated if unset.
TRIPWEAVER_API_KEYS=change-me-to-a-long-random-string
# Comma-separated list of allowed CORS origins, e.g. your deployed frontend
# URL and localhost ports used for local Next.js development.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3010
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
MAX_MESSAGE_LENGTH=2000

# --- Account history ------------------------------------------------------
# Local dev defaults to backend/data/tripweaver.sqlite3. For the Vercel +
# Render + Supabase demo, set DATABASE_URL to your Supabase Postgres connection
# string in Render. If DATABASE_URL is set, it wins over TRIPWEAVER_DB_PATH.
TRIPWEAVER_DB_PATH=backend/data/tripweaver.sqlite3
DATABASE_URL=

# Used only by the backend to verify Supabase social-login access tokens.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
