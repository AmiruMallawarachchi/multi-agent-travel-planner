# Copy to .env for local dev. In Railway, set as service Variables.

# Get free TEST credentials at https://developers.amadeus.com (self-service,
# instant approval - these hit test.api.amadeus.com, not production data).
AMADEUS_CLIENT_ID=your-amadeus-test-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-test-client-secret
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Local dev default; Railway sets PORT for you automatically.
PORT=8001
